    "MTG-PL-2025-10-07-PVCRE-ITM-13": {
      "id": "eli/dl/event/MTG-PL-2025-10-07-PVCRE-ITM-13",
      "type": "Activity",
      "activity_date": "2025-10-07",
      "activity_end_date": "2025-10-07T19:43:56.464+02:00",
      "activity_id": "MTG-PL-2025-10-07-PVCRE-ITM-13",
      "activity_label": {
        "es": "13. Situación en Afganistán: apoyo a las mujeres y comunidades afectadas por los recientes terremotos (debate)",
        "sl": "13. Razmere v Afganistanu: podpora ženskam in skupnostim, ki so jih prizadeli nedavni potresi (razprava)",
        "da": "13. Situationen i Afghanistan: støtte til kvinder og samfund berørt af de seneste jordskælv (forhandling)",
        "bg": "13. Положението в Афганистан: подкрепа за жените и общностите, засегнати от неотдавнашните земетресения (разискване)",
        "et": "13. Olukord Afganistanis: hiljutistest maavärinatest mõjutatud naiste ja kogukondade toetamine (arutelu)",
        "ga": "13. An staid san Afganastáin: tacaíocht a thabhairt do mhná agus do phobail atá buailte ag na creathanna talún a tharla le déanaí (díospóireacht)",
        "pl": "13. Sytuacja w Afganistanie: wsparcie kobiet i społeczności poszkodowanych w wyniku niedawnego trzęsienia ziemi (debata)",
        "hr": "13. Stanje u Afganistanu: potpora ženama i zajednicama pogođenima nedavnim potresima (rasprava)",
        "lt": "13. Padėtis Afganistane: parama moterims ir neseniai įvykusių žemės drebėjimų paveiktoms bendruomenėms (diskusijos)",
        "cs": "13. Situace v Afghánistánu: podpora žen a komunit, kterých se dotkla nedávná zemětřesení (rozprava)",
        "ro": "13. Situația din Afganistan: sprijinirea femeilor și a comunităților afectate de cutremurele recente (dezbatere)",
        "en": "13. Situation in Afghanistan: supporting women and communities affected by the recent earthquakes (debate)",
        "lv": "13. Stāvoklis Afganistānā: atbalsts sievietēm un kopienām, kas cietušas nesenajās zemestrīcēs (debates)",
        "fi": "13. Afganistanin tilanne: naisten ja yhteisöjen tukeminen äskettäisten maanjäristysten vaikutusten vuoksi (keskustelu)",
        "el": "13. Η κατάσταση στο Αφγανιστάν: στήριξη στις γυναίκες και στις κοινότητες που επλήγησαν από τους πρόσφατους σεισμούς (συζήτηση)",
        "nl": "13. Situatie in Afghanistan: ondersteuning van vrouwen en gemeenschappen die zijn getroffen door de recente aardbevingen (debat)",
        "fr": "13. Situation en Afghanistan: soutenir les femmes et les communautés touchées par les récents tremblements de terre (débat)",
        "it": "13. Situazione in Afghanistan: sostenere le donne e le comunità colpite dai recenti terremoti (discussione)",
        "mt": "13. Is-sitwazzjoni fl-Afganistan: nappoġġjaw lin-nisa u lill-komunitajiet milquta mit-terremoti reċenti (dibattitu)",
        "sv": "13. Situationen i Afghanistan: stöd till kvinnor och lokalsamhällen som drabbats av den senaste tidens jordbävningar (debatt)",
        "hu": "13. Az afganisztáni helyzet: a közelmúltbeli földrengések által érintett nők és közösségek támogatása (vita)",
        "de": "13. Lage in Afghanistan: Unterstützung von Frauen und Gemeinden, die von den jüngsten Erdbeben betroffen sind (Aussprache)",
        "pt": "13. A situação no Afeganistão: apoiar as mulheres e as comunidades afetadas pelos recentes terramotos (debate)",
        "sk": "13. Situácia v Afganistane: podpora žien a komunít postihnutých nedávnymi zemetraseniami (rozprava)"
      },
